  "schedules": [
    {
      "semester": "2023-2nd",
      "year": 2023,
      "weeks": [
        {
          "week": 1,
          "topic": "Introduction to Ray Tracing",
          "description": "Fundamentals of ray tracing, history, and basic concepts in computer graphics."
        },
        {
          "week": 2,
          "topic": "Ray-Surface Interactions",
          "description": "Understanding how rays interact with surfaces and mathematical foundations."
        },
        {
          "week": 3,
          "topic": "Reflection and Refraction",
          "description": "Modeling specular and diffuse reflections, refraction, and Snell's law applications."
        },
        {
          "week": 4,
          "topic": "Lighting Models",
          "description": "Phong, Blinn-Phong, and PBR lighting models for realistic shading."
        },
        {
          "week": 5,
          "topic": "Acceleration Structures",
          "description": "BVH, KD-trees, and spatial partitioning for efficient ray intersection testing."
        },
        {
          "week": 6,
          "topic": "Path Tracing Basics",
          "description": "Introduction to path tracing algorithm and Monte Carlo integration."
        },
        {
          "week": 7,
          "topic": "Advanced Rendering Techniques",
          "description": "Caustics, subsurface scattering, and advanced light transport methods."
        },
        {
          "week": 8,
          "topic": "Real-time Ray Tracing",
          "description": "Optimization techniques and strategies for real-time ray tracing applications."
        },
        {
          "week": 9,
          "topic": "GPU-Based Ray Tracing",
          "description": "CUDA, OptiX, and GPU acceleration for high-performance ray tracing."
        },
        {
          "week": 10,
          "topic": "Denoising and Post-Processing",
          "description": "Noise reduction techniques and image processing for ray-traced images."
        },
        {
          "week": 11,
          "topic": "Special Effects and Motion Blur",
          "description": "Implementing motion blur, depth of field, and other temporal effects."
        },
        {
          "week": 12,
          "topic": "Volumetric Rendering",
          "description": "Rendering fog, smoke, clouds, and participating media."
        },
        {
          "week": 13,
          "topic": "Ray Tracing in Video Games",
          "description": "Real-world applications in game engines like Unreal and Unity."
        },
        {
          "week": 14,
          "topic": "Industry Tools and Techniques",
          "description": "Overview of production renderers like RenderMan, Arnold, and V-Ray."
        },
        {
          "week": 15,
          "topic": "Final Project Presentations",
          "description": "Student presentations of their ray tracing projects and rendering results."
        }
      ]
    },
